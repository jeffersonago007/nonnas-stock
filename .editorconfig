root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{java,sql}]
indent_size = 4

[*.{ts,tsx,js,jsx,json,yml,yaml,xml,html,css,md}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{ps1,bat,cmd}]
end_of_line = crlf
indent_size = 4
