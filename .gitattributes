# Default: text files normalized to LF
* text=auto eol=lf

# Source code
*.java     text eol=lf
*.kt       text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.xml      text eol=lf
*.sql      text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.md       text eol=lf
*.sh       text eol=lf
Dockerfile text eol=lf
Makefile   text eol=lf

# Windows scripts keep CRLF
*.ps1      text eol=crlf
*.bat      text eol=crlf
*.cmd      text eol=crlf

# Binaries
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.svg      text eol=lf
*.pdf      binary
*.zip      binary
*.gz       binary
*.tar      binary
*.xlsx     binary
*.xls      binary
*.docx     binary
*.jar      binary
