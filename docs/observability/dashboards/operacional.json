{
  "title": "Nonnas Stock — Operacional",
  "description": "Master doc 15.2: requisições/min por endpoint, latência p50/p95/p99, taxa de erro 4xx/5xx, uso de conexões HikariCP. Importar em Grafana via 'Dashboards → Import → JSON'.",
  "tags": ["nonnas", "operacional", "spring-boot"],
  "timezone": "America/Sao_Paulo",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Requisições por minuto",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count[1m])) * 60",
          "legendFormat": "{{uri}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Latência p95 por endpoint (s)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (uri, le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p95 {{uri}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Latência p50/p95/p99 (geral)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "Taxa de erro 4xx/5xx",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"4..\"}[5m]))",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "type": "stat",
      "title": "HikariCP em uso",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "hikaricp_connections_active",
          "legendFormat": "ativas"
        },
        {
          "expr": "hikaricp_connections_idle",
          "legendFormat": "idle"
        }
      ],
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 }
    },
    {
      "type": "timeseries",
      "title": "JVM heap usage",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{id}}"
        }
      ],
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 }
    }
  ]
}
